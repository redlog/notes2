NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required only for the migration script (scripts/migrate.mjs)
# Find this in your Supabase project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Local SQLite mode ────────────────────────────────────────────────────────
# Set PROVIDER=sqlite to run the app locally without Supabase or authentication.
# The Supabase env vars above are not needed in this mode.
#
# PROVIDER=sqlite
#
# Optional: path to the SQLite database file (default: <cwd>/local-data/notes.db)
# SQLITE_DB_PATH=/path/to/your/OneDrive/notes/notes.db
#
# Optional: directory for image attachments (default: next to the DB file in "images/")
# LOCAL_IMAGES_DIR=/path/to/your/OneDrive/notes/images
